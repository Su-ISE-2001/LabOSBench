  "comparison_with_osworld": {
    "osworld_rate": 72.36,
    "labosbench_best_subtask": 81.4,
    "labosbench_end_to_end": 26.3,
    "note": "Best subtask agent (GTA1) reaches 81.4%, but GPT-5.5 end-to-end is only 26.3%, reflecting error accumulation in long scientific workflows"
  },
  "findings": [
    "Subtask-level evaluation reveals local GUI-agent limits; end-to-end evaluation exposes severe error accumulation",
    "General multimodal models outperform specialized GUI models overall, but still struggle on feedback-heavy and long-horizon tasks",
    "Agentic frameworks (e.g. GTA1) help only when recovery strategies align with instrument-operation semantics",
    "LabOSBench jointly stresses GUI grounding, scientific state understanding, sequential control, and continuous visual adjustment"
  ]
