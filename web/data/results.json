    {
      "category": "Visual grounding failures",
      "description": "Failure to locate controls, buttons, or target regions in instrument software (widget grounding)"
    },
    {
      "category": "Limited scientific state understanding",
      "description": "Alignment, focus, and image-adjustment tasks require interpreting scientific visual state and closed-loop control"
    },
    {
      "category": "Long-horizon planning & error accumulation",
      "description": "Multi-step workflows fail on ordering, state memory, or recovery (end-to-end success only 26.3%)"
    },
    {
      "category": "Domain-specific instrument GUIs",
      "description": "General GUI grounding is insufficient for instrument-specific widgets (sliders, heatmaps, multi-state indicators, etc.)"
    }
