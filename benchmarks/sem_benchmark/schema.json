{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GUIAgentSEMTaskEpisode",
  "description": "Log format for a single GUIAgent episode on the SEM simulator task.",
  "type": "object",
  "required": ["task_id", "episode_id", "env", "success", "summary", "grounding_metrics", "subtasks", "steps"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Task identifier, e.g. 'SEM-Scan-And-Save-01'."
    },
    "episode_id": {
      "type": "string",
      "description": "Unique id for this run/episode."
    },
    "env": {
      "type": "string",
      "description": "Environment name, e.g. 'SEM_Simulator'."
    },
    "agent_name": {
      "type": "string",
      "description": "Optional. Name or version of the agent.",
      "nullable": true
    },
    "success": {
      "type": "boolean",
      "description": "Whether the overall task is successfully completed (all subtasks S1–S11 for SEM-Scan-And-Save-01, or S12 for SEM-Mosaic-ROI-01)."
    },
    "timestamps": {
      "type": "object",
      "properties": {
        "start_time": {"type": "string", "format": "date-time"},
        "end_time": {"type": "string", "format": "date-time"},
        "duration_sec": {"type": "number"}
      },
      "required": ["duration_sec"]
    },
    "summary": {
      "type": "object",
      "required": ["optimal_steps", "actual_steps", "step_efficiency"],
      "properties": {
        "optimal_steps": {"type": "integer", "minimum": 0},
        "actual_steps": {"type": "integer", "minimum": 0},
        "step_efficiency": {"type": "number", "minimum": 0}
      }
    },
    "grounding_metrics": {
      "type": "object",
      "required": ["widget_grounding_accuracy", "text_grounding_accuracy", "state_grounding_accuracy"],
      "properties": {
        "widget_grounding_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "text_grounding_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "state_grounding_accuracy": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "quality_metrics": {
      "type": "object",
      "description": "Optional. Quality scores from local comparison between current capture and reference center-crop.",
      "properties": {
        "local_compare_method": {"type": "string"},
        "evaluations": {"type": "integer", "minimum": 0},
        "latest_score": {"type": "number", "minimum": 0, "maximum": 100, "nullable": true},
        "best_score": {"type": "number", "minimum": 0, "maximum": 100, "nullable": true},
        "average_score": {"type": "number", "minimum": 0, "maximum": 100, "nullable": true}
      }
    },
    "subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subtask_id", "name", "success", "attempts"],
        "properties": {
          "subtask_id": {"type": "string"},
          "name": {"type": "string"},
          "success": {"type": "boolean"},
          "attempts": {"type": "integer", "minimum": 0},
          "notes": {"type": "string"},
          "phase": {"type": "string"},
          "grounding_focus": {
            "type": "array",
            "items": {"type": "string"}
          },
          "success_criteria": {"type": "string"}
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "timestamp_offset_sec", "subtask_id", "action_type", "target", "hit_expected_target", "relies_on_text", "state_snapshot"],
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "timestamp_offset_sec": {"type": "number", "minimum": 0},
          "subtask_id": {"type": "string"},
          "action_type": {"type": "string", "enum": ["click", "select", "input", "wait", "custom"]},
          "target": {
            "type": "object",
            "properties": {
              "dom_selector": {"type": "string", "nullable": true},
              "bbox": {"type": "array", "items": {"type": "number"}},
              "text": {"type": "string", "nullable": true}
            }
          },
          "hit_expected_target": {"type": "boolean"},
          "relies_on_text": {"type": "boolean"},
          "chosen_text": {"type": "string", "nullable": true},
          "image_quality": {
            "type": "object",
            "nullable": true,
            "properties": {
              "score": {"type": "number", "minimum": 0, "maximum": 100},
              "mse": {"type": "number", "minimum": 0, "nullable": true},
              "psnr": {"type": "number", "nullable": true},
              "ssim_approx": {"type": "number", "nullable": true},
              "sharpness_ratio": {"type": "number", "minimum": 0, "nullable": true}
            }
          },
          "state_snapshot": {
            "type": "object",
            "properties": {
              "chamber_open": {"type": "boolean", "nullable": true},
              "sample_placed": {"type": "boolean", "nullable": true},
              "ht_on": {"type": "boolean", "nullable": true},
              "acc_voltage_kv": {"type": "number", "nullable": true},
              "spot_size_nm": {"type": "number", "nullable": true},
              "working_distance": {"type": "number", "nullable": true},
              "last_scan_mode": {"type": "string", "nullable": true}
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
